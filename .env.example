# ========================================
# Tienda_DS_MS - Configuración Docker
# ========================================
# Copiar este archivo a .env.docker.local y configurar con tus valores

# ==========================================
# MySQL Configuration
# ==========================================
MYSQL_ROOT_PASSWORD=Mojang_24
MYSQL_USER=tienda_user
MYSQL_PASSWORD=TiendaPass123!

# ==========================================
# JWT Configuration
# ==========================================
# Generar una clave segura: openssl rand -base64 32
JWT_KEY=ClaveSuperSecretaParaProduccionDe256BitsAWS!!2025
JWT_ISSUER=TiendaMS
JWT_AUDIENCE=TiendaFrontend
JWT_EXPIRATION_MINUTES=60

# ==========================================
# Application Environment
# ==========================================
ASPNETCORE_ENVIRONMENT=Docker
ASPNETCORE_URLS=http://+:8080;https://+:8081
ASPNETCORE_HTTPS_PORT=8081

# ==========================================
# Logging
# ==========================================
LOG_LEVEL=Information
LOG_LEVEL_ASPNETCORE=Warning
LOG_LEVEL_DATABASE=Information

# ==========================================
# CORS Configuration
# ==========================================
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://tienda-web,https://localhost

# ==========================================
# API Configuration
# ==========================================
API_PORT=8080
API_HEALTH_CHECK_INTERVAL=30

# ==========================================
# Frontend Configuration
# ==========================================
WEB_PORT=80
WEB_HTTPS_PORT=443
API_URL=http://tienda-api:8080

# ==========================================
# Database Configuration
# ==========================================
DB_HOST=mysql-db
DB_PORT=3306
DB_CHARSET=utf8mb4

# ==========================================
# Container Names
# ==========================================
DB_CONTAINER_NAME=tienda-ds-mysql
API_CONTAINER_NAME=tienda-ds-api
WEB_CONTAINER_NAME=tienda-ds-web

# ==========================================
# Volume Names
# ==========================================
DB_VOLUME_NAME=mysql-data

# ==========================================
# Network
# ==========================================
NETWORK_NAME=tienda-network

# ==========================================
# Backup Configuration
# ==========================================
BACKUP_SCHEDULE=0 2 * * *  # 2 AM daily
BACKUP_RETENTION_DAYS=30

# ==========================================
# Production Configuration (descomenta para producción)
# ==========================================
# ENVIRONMENT=production
# DEBUG_MODE=false
# SSL_ENABLED=true
# SSL_CERT_PATH=/etc/ssl/certs/cert.pem
# SSL_KEY_PATH=/etc/ssl/private/key.pem

# ==========================================
# AWS Configuration (si usas AWS)
# ==========================================
# AWS_REGION=us-east-2
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_RDS_ENDPOINT=your-rds-endpoint.rds.amazonaws.com

# ==========================================
# Email Configuration (para notificaciones)
# ==========================================
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM_ADDRESS=noreply@tienda.com

# ==========================================
# Monitoring (si usas stack ELK o similar)
# ==========================================
# ELASTICSEARCH_URL=http://elasticsearch:9200
# KIBANA_URL=http://kibana:5601
# PROMETHEUS_URL=http://prometheus:9090
